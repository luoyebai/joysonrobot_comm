$struct.scopedname$::$struct.name$(
        const $struct.scopedname$& x)
    $if(struct.inheritance)$
    : $struct_inherit_copy_init(struct.inheritance)$
    $endif$

{
    $if(struct.members)$
    $struct.members:{ member | $member_copy(ctx=ctx, member=member)$}; separator="\n"$
    $else$
    static_cast<void>(x);
    $endif$
    is_compute_key_provided = x.is_compute_key_provided;
    max_serialized_type_size = x.max_serialized_type_size;
    uint32_t keyLength = $struct.cScopedname$_max_key_cdr_typesize > 16 ? $struct.cScopedname$_max_key_cdr_typesize : 16;
    m_keyBuffer = reinterpret_cast<unsigned char*>(malloc(keyLength));
    memcpy(m_keyBuffer, x.m_keyBuffer, keyLength);
}

$struct.scopedname$::$struct.name$(
        $struct.scopedname$&& x) noexcept
    $if(struct.inheritance)$
    : $struct_inherit_move_init(struct.inheritance)$
    $endif$

{
