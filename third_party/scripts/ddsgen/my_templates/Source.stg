$struct.scopedname$& $struct.scopedname$::operator =(
        const $struct.scopedname$& x)
{
    $if(struct.inheritance)$$struct.inheritance.scopedname$::operator =(x);$endif$


    if (this != &x) {
        $if(struct.members)$
