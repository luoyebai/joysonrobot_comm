





group TypesCdrAuxHeader;

fileHeader(ctx, file, description) ::= <<

/*!
 * @file $file$
 * $description$
 *
 * This file was generated by the tool $ctx.product$gen.
 */
>>


main(ctx, definitions, extensions) ::= <<
$fileHeader(ctx=ctx, file=[ctx.filename, ".pybind.ipp"], description=["The original file contains some type bindings for Pybind11."])$

$definitions; separator="\n"$

$"\n"$
>>

module(ctx, parent, module, definition_list) ::= <<
$definition_list$
>>

definition_list(definitions) ::= <<
$definitions; separator="\n"$

>>

annotation(ctx, annotation) ::= <<>>

interface(ctx, parent, interface, export_list) ::= <<
$export_list$
>>

export_list(exports) ::= <<
$exports; separator="\n"$

>>

fwd_decl(ctx, parent, type) ::= <<>>

exception(ctx, parent, exception) ::= <<>>

operation(ctx, parent, operation, param_list, operation_type) ::= <<

$operation_type$
$param_list$

>>

param_list(parameters) ::= <<>>

param(parameter, parameter_type) ::= <<

$parameter_type$

>>

const_decl(ctx, parent, const, const_type) ::= <<

$const_type$

>>

typedef_decl(ctx, parent, typedefs, typedefs_type, declarator_type) ::= <<

$declarator_type$
$typedefs_type$

>>

member_type_declaration(member) ::= <%

$if(member.typecode.isArrayType)$
    const 
$endif$
$if(member.typecode.isSequenceType)$
    const 
$endif$
$if(member.typecode.isStringType)$
    const 
$endif$
$if(member.typecode.isStructType)$
    const 
$endif$
$if(member.typecode.isUnionType)$
    const 
$endif$
$if(member.typecode.isMapType)$
    const 
$endif$
$if(member.typecode.isBitsetType)$
    const 
$endif$
$if(member.typecode.isBitmaskType)$
    const 
$endif$


$if(member.annotationOptional)$
    eprosima::fastcdr::optional<
$endif$
$if(member.annotationExternal)$
    eprosima::fastcdr::external<
$endif$

$member.typecode.cppTypename$

$if(member.annotationExternal)$
    >
$endif$
$if(member.annotationOptional)$
    >
$endif$

$if(member.typecode.isArrayType)$
    &
$endif$
$if(member.typecode.isSequenceType)$
    &
$endif$
$if(member.typecode.isStringType)$
    &
$endif$
$if(member.typecode.isStructType)$
    &
$endif$
$if(member.typecode.isUnionType)$
    &
$endif$
$if(member.typecode.isMapType)$
    &
$endif$
$if(member.typecode.isBitsetType)$
    &
$endif$
$if(member.typecode.isBitmaskType)$
    &
$endif$
%>

member_pybind(ctx, type_name, member) ::= <%
.def_property("$member.name$",
              ($member_type_declaration(member)$ ($type_name$::*)() const) & $type_name$::$member.name$,
              (void($type_name$::*)($member_type_declaration(member)$)) &  $type_name$::$member.name$)
%>


struct_type(ctx, parent, struct, extensions, member_list) ::= <<
$member_list$

py::class_<$struct.scopedname$>(m, "$struct.name$")
    .def(py::init<>())
    .def(py::init<const $struct.scopedname$&>())
    $if(struct.allMembers)$
    $struct.allMembers:{ member | $member_pybind(ctx=ctx, type_name=struct.scopedname, member=member)$}; separator="\n"$
    $endif$
    .def("__eq__", &$struct.scopedname$::operator==)
    .def("__ne__", &$struct.scopedname$::operator!=);
>>

member_type(ctx, member, type_member, declarators) ::= <<

$type_member$
$declarators$

>>

bitset_type(ctx, parent, bitset) ::= <<

py::class_<$bitset.scopedname$>(m, "$bitset.name$")
    .def(py::init<>())
    .def(py::init<const $bitset.scopedname$&>())
    $if(bitset.bitfields)$
    $bitset.bitfields:{ member | .def_property("$member.name$", ($member.spec.cppTypename$ ($bitset.scopedname$::*)() const)& $bitset.scopedname$::$member.name$,(void($bitset.scopedname$::*)($member.spec.cppTypename$))& $bitset.scopedname$::$member.name$)}; separator="\n"$
    $endif$
    .def("__eq__", &$bitset.scopedname$::operator==)
    .def("__ne__", &$bitset.scopedname$::operator!=);
>>

public_bitfield_definition(member) ::= <<>>

union_type(ctx, parent, union, switch_type) ::= <<
$switch_type$
py::class_<$union.scopedname$>(m, "$union.name$")
    .def(py::init<>())
    .def(py::init<const $union.scopedname$&>())
    .def_property("_d", ($union.discriminator.cppTypename$ ($union.scopedname$::*)() const) &$union.scopedname$::_d,
    (void ($union.scopedname$::*)($union.discriminator.cppTypename$)) &$union.scopedname$::_d)
    $if(union.membersDefaultAtEnd)$
    $union.membersDefaultAtEnd:{ member | $member_pybind(ctx=ctx, type_name=union.scopedname, member=member)$}; separator="\n"$
    $endif$
    .def("__eq__", &$union.scopedname$::operator==)
    .def("__ne__", &$union.scopedname$::operator!=);
>>

element_type(ctx, element, type_element, declarator) ::= <<

$type_element$
$declarator$

>>

enum_type(ctx, parent, enum) ::= <<
py::enum_<$enum.scopedname$>(m, "$enum.name$")
    $enum.members:{ member | .value("$member.name$", $enum.scopedname$::$member.name$)}; separator="\n"$
    .export_values();
>>

bitmask_type(ctx, parent, bitmask) ::= <<

py::enum_<$bitmask.scopedname$Bits>(m, "$bitmask.name$Bits", py::arithmetic())
    $bitmask.members:{ member | .value("$member.name$", $bitmask.scopedname$Bits::$member.name$)}; separator="\n"$;
>>

sequence_type(ctx, sequence, type_sequence) ::= <<

$type_sequence$

>>

map_type(ctx, map, key_type, value_type) ::= <<
$key_type$
$value_type$
>>

string_type(ctx, string) ::= <<>>

wide_string_type(ctx, wstring) ::= <<>>

array_declarator(ctx, array, array_type) ::= <<>>
